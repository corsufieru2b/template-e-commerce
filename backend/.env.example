# Backend Configuration
NODE_ENV=development
PORT=5000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/ecommerce
# Pour MongoDB Atlas: MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ecommerce

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_EXPIRE=7d

# Branding & Configuration
STORE_NAME=Premium Store
STORE_EMAIL=contact@premium-store.com

# Security
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@premium-store.com
SUPPORT_CONTACT_EMAIL=contact@premium-store.com

# Logger
LOG_LEVEL=debug
